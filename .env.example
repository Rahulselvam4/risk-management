# .env.example - Email Alert Configuration Template
# Copy this to .env and fill in your actual values

# ============================================
# EMAIL ALERT CONFIGURATION
# ============================================

# SMTP Server Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SMTP Credentials
# For Gmail: Use App Password (not your regular password)
# 1. Enable 2FA: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character password below
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# Email Display Settings
ALERT_FROM_EMAIL=noreply@riskdashboard.com
ALERT_FROM_NAME=Risk Dashboard Alerts

# Dashboard URL (for email links)
DASHBOARD_URL=http://localhost:8050

# ============================================
# EXISTING CONFIGURATION (Keep your values)
# ============================================

# Database
DB_HOST=localhost
DB_NAME=risk_management
DB_USER=root
DB_PASSWORD=your-db-password

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Kafka
KAFKA_BROKER=localhost:29092
KAFKA_TOPIC=market_data_topic

# Google OAuth (if using)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# API URL
API_URL=http://127.0.0.1:8000
